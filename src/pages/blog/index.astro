---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import ArticleCard from '@/components/ArticleCard.astro';
import { getImageIntent, LANDSCAPE_PHOTOS } from '@/data/images';
import { CATEGORIES } from '@/data/categories';

const articles = (await getCollection('blog'))
  .filter((article) => !article.data.draft)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const categoryCounts = new Map<string, number>();
const imageIndexes = new Map<string, number>();
for (const article of articles) {
  const category = getImageIntent([article.data.title, article.slug, article.data.category, ...(article.data.tags ?? [])].join(' '), article.data.category);
  const nextIndex = categoryCounts.get(category) ?? 0;
  imageIndexes.set(article.slug, nextIndex);
  categoryCounts.set(category, nextIndex + 1);
}

const byCategory = (category: string) => articles.filter((article) => article.data.category === category);
type BlogArticle = (typeof articles)[number];
const isArticle = (article: BlogArticle | undefined): article is BlogArticle => Boolean(article);
const featuredArticles = [
  articles.find((article) => article.data.title.includes('Premium')),
  articles.find((article) => article.data.title.includes('Curb Appeal')),
  articles.find((article) => article.data.title.includes('Walkway'))
].filter(isArticle).slice(0, 3);
const featuredSlugs = new Set(featuredArticles.map((article) => article.slug));
const trendingIdeas = [
  ...articles.filter((article) => /modern|rock|walkway|flower bed|low maintenance/i.test(`${article.data.title} ${article.slug}`))
].filter((article) => !featuredSlugs.has(article.slug)).slice(0, 6);
const popularThisWeek = CATEGORIES.map((category) => byCategory(category.name)[0]).filter(isArticle).slice(0, 8);
const latestArticles = articles;
const totalReadingGuides = articles.length;
const seoDescription = 'Browse the Front Yard Aura editorial magazine for premium front yard landscaping ideas, curb appeal inspiration, walkways, flower beds, rock landscaping, low maintenance yards, and American home exterior design.';
---

<BaseLayout
  title="Front Yard Landscaping Blog"
  description={seoDescription}
  path="/blog/"
  image={LANDSCAPE_PHOTOS.luxuryCurbAppeal}
  type="website"
>
  <section class="bg-aura-forest text-aura-ivory">
    <div class="container-page grid gap-10 py-12 md:grid-cols-[1.08fr_0.92fr] md:items-end md:py-20">
      <div>
        <p class="eyebrow text-aura-brass">Premium Editorial Magazine</p>
        <h1 class="mt-3 max-w-4xl font-serif text-5xl font-bold leading-tight md:text-7xl">Front Yard Landscaping Blog</h1>
        <p class="mt-5 max-w-3xl text-lg leading-8 text-aura-ivory/78">
          A curated library of save-worthy front yard landscaping ideas for American homes: curb appeal, walkways, flower beds, rock landscaping, luxury exteriors, and low-maintenance yards that look polished from the street.
        </p>
      </div>
      <form class="rounded-2xl border border-white/12 bg-white/[0.07] p-4 shadow-premium backdrop-blur md:p-5" action="/search" method="get" role="search">
        <label class="sr-only" for="q">Search articles</label>
        <div class="flex flex-col gap-3 sm:flex-row">
          <input id="q" name="q" class="min-h-12 min-w-0 flex-1 rounded-full border border-white/15 bg-white/10 px-5 text-sm text-white placeholder:text-white/50" placeholder="Search curb appeal, walkways, rocks..." />
          <button class="btn-primary bg-aura-brass text-aura-forest hover:bg-aura-sand" type="submit">Search</button>
        </div>
        <p class="mt-4 text-sm font-semibold text-aura-ivory/70">{totalReadingGuides} editorial guides, organized by project style and curb appeal goal.</p>
      </form>
    </div>
  </section>

  <nav class="sticky top-[7.75rem] z-30 border-b border-aura-linen bg-aura-ivory/92 backdrop-blur md:top-20" aria-label="Blog categories">
    <div class="container-page flex gap-2 overflow-x-auto py-3">
      <button class="shrink-0 rounded-full border border-aura-brass bg-aura-pine px-4 py-2 text-xs font-bold uppercase tracking-[0.12em] text-white transition hover:-translate-y-0.5 hover:shadow-soft" type="button" data-blog-filter="all" aria-controls="latest-articles" aria-pressed="true">
        All
      </button>
      {CATEGORIES.map((category) => (
        <button class="shrink-0 rounded-full border border-aura-linen bg-aura-porcelain px-4 py-2 text-xs font-bold uppercase tracking-[0.12em] text-aura-pine transition hover:-translate-y-0.5 hover:border-aura-brass hover:text-aura-clay hover:shadow-soft" type="button" data-blog-filter={category.name} aria-controls="latest-articles" aria-pressed="false">
          {category.shortName}
        </button>
      ))}
    </div>
  </nav>

  <section class="container-page py-12 md:py-16" aria-labelledby="featured-heading">
    <div class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
      <div>
        <p class="eyebrow">Featured Articles</p>
        <h2 id="featured-heading" class="mt-2 font-serif text-4xl font-bold leading-tight text-aura-pine md:text-5xl">Magazine picks for a better first impression.</h2>
      </div>
      <a class="btn-secondary w-fit" href="/ideas/">Explore idea hubs</a>
    </div>
    <div class="mt-8 grid gap-5 lg:grid-cols-[1.35fr_0.9fr]">
      {featuredArticles[0] && <ArticleCard article={featuredArticles[0]} imageIndex={imageIndexes.get(featuredArticles[0].slug)} variant="featured" />}
      <div class="grid gap-5">
        {featuredArticles.slice(1).map((article) => <ArticleCard article={article} imageIndex={imageIndexes.get(article.slug)} variant="compact" />)}
      </div>
    </div>
  </section>

  <section class="section-band py-12 md:py-16" aria-labelledby="trending-heading">
    <div class="container-page">
      <div class="max-w-3xl">
        <p class="eyebrow">Trending Ideas</p>
        <h2 id="trending-heading" class="mt-2 font-serif text-4xl font-bold leading-tight text-aura-pine md:text-5xl">The details homeowners are saving right now.</h2>
      </div>
      <div class="mt-8 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
        {trendingIdeas.map((article) => <ArticleCard article={article} imageIndex={imageIndexes.get(article.slug)} />)}
      </div>
    </div>
  </section>

  <section class="container-page py-12 md:py-16" aria-labelledby="popular-heading">
    <div class="grid gap-8 lg:grid-cols-[0.78fr_1.22fr] lg:items-start">
      <div class="lg:sticky lg:top-24">
        <p class="eyebrow">Popular This Week</p>
        <h2 id="popular-heading" class="mt-2 font-serif text-4xl font-bold leading-tight text-aura-pine">Fast paths into the archive.</h2>
        <p class="mt-4 text-base leading-7 text-aura-ink/75">
          Start with the major front yard goals: smaller spaces, modern exteriors, budget upgrades, flower beds, rocks, walkways, and low-maintenance curb appeal.
        </p>
      </div>
      <div class="grid gap-3 sm:grid-cols-2">
        {popularThisWeek.map((article, index) => (
          <a class="group rounded-xl border border-aura-linen bg-aura-porcelain p-4 shadow-soft transition hover:-translate-y-0.5 hover:border-aura-brass hover:shadow-premium" href={`/blog/${article.slug}/`}>
            <span class="text-xs font-extrabold uppercase tracking-[0.16em] text-aura-clay">0{index + 1}</span>
            <h3 class="mt-2 font-serif text-2xl font-semibold leading-tight text-aura-pine transition group-hover:text-aura-clay">{article.data.title}</h3>
            <p class="mt-2 text-sm font-bold uppercase tracking-[0.12em] text-aura-moss">{article.data.category}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-aura-forest py-12 text-aura-ivory md:py-16" aria-labelledby="categories-heading">
    <div class="container-page">
      <p class="eyebrow text-aura-brass">Category Guides</p>
      <h2 id="categories-heading" class="mt-2 max-w-3xl font-serif text-4xl font-bold leading-tight md:text-5xl">Browse by landscaping mood, material, and maintenance level.</h2>
      <div class="mt-8 grid gap-4 md:grid-cols-2 lg:grid-cols-4">
        {CATEGORIES.map((category) => (
          <a class="rounded-2xl border border-white/12 bg-white/[0.07] p-5 transition hover:-translate-y-1 hover:border-aura-brass hover:bg-white/[0.1]" href={`/ideas/${category.slug}/`}>
            <p class="text-xs font-bold uppercase tracking-[0.16em] text-aura-brass">{category.accent}</p>
            <h3 class="mt-2 font-serif text-2xl font-semibold leading-tight">{category.shortName}</h3>
            <p class="mt-3 text-sm leading-6 text-aura-ivory/72">{category.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section id="latest-articles" class="container-page py-12 md:py-16" aria-labelledby="latest-heading">
    <div class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
      <div>
        <p class="eyebrow" data-filter-kicker>Latest Articles</p>
        <h2 id="latest-heading" class="mt-2 font-serif text-4xl font-bold leading-tight text-aura-pine md:text-5xl">Fresh landscaping inspiration.</h2>
        <p class="mt-3 text-sm font-bold uppercase tracking-[0.12em] text-aura-moss" data-filter-count>{latestArticles.length} articles</p>
      </div>
      <a class="btn-secondary w-fit" href="/search/">Search archive</a>
    </div>
    <div class="mt-8 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
      {latestArticles.length > 0 ? latestArticles.map((article) => (
        <div data-blog-card data-category={article.data.category}>
          <ArticleCard article={article} imageIndex={imageIndexes.get(article.slug)} />
        </div>
      )) : (
        <p class="rounded-lg border border-aura-linen bg-aura-porcelain p-6 text-aura-ink/85 shadow-soft">No published articles are available yet.</p>
      )}
    </div>
  </section>

  <script is:inline>
    const filterButtons = document.querySelectorAll('[data-blog-filter]');
    const articleCards = document.querySelectorAll('[data-blog-card]');
    const latestSection = document.querySelector('#latest-articles');
    const filterKicker = document.querySelector('[data-filter-kicker]');
    const filterCount = document.querySelector('[data-filter-count]');

    filterButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const filter = button.getAttribute('data-blog-filter');
        let visibleCount = 0;

        filterButtons.forEach((item) => {
          const isActive = item === button;
          item.classList.toggle('bg-aura-pine', isActive);
          item.classList.toggle('text-white', isActive);
          item.classList.toggle('border-aura-brass', isActive);
          item.classList.toggle('bg-aura-porcelain', !isActive);
          item.classList.toggle('text-aura-pine', !isActive);
          item.setAttribute('aria-pressed', String(isActive));
        });

        articleCards.forEach((card) => {
          const matches = filter === 'all' || card.getAttribute('data-category') === filter;
          card.toggleAttribute('hidden', !matches);
          if (matches) visibleCount += 1;
        });

        if (filterKicker) {
          filterKicker.textContent = filter === 'all' ? 'Latest Articles' : filter;
        }

        if (filterCount) {
          filterCount.textContent = `${visibleCount} article${visibleCount === 1 ? '' : 's'}`;
        }

        latestSection?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    });
  </script>

  <script is:inline type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'Front Yard Landscaping Blog',
    description: seoDescription,
    url: 'https://frontyardaura.com/blog/',
    about: ['front yard landscaping', 'curb appeal', 'walkways', 'flower beds', 'rock landscaping', 'low maintenance yards'],
    mainEntity: articles.slice(0, 12).map((article) => ({
      '@type': 'BlogPosting',
      headline: article.data.title,
      description: article.data.description,
      url: `https://frontyardaura.com/blog/${article.slug}/`,
      datePublished: article.data.publishDate.toISOString()
    }))
  })} />
</BaseLayout>
