---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ImageOverlayCard from '@/components/ImageOverlayCard.astro';
import TrustStrip from '@/components/TrustStrip.astro';
import { getImageForText, photo } from '@/data/images';
import type { OverlayPosition } from '@/data/images';

type HomeImageCard = {
  title: string;
  label: string;
  image: string;
  position: OverlayPosition;
  copy: string;
};

type HomeIdeaSection = {
  title: string;
  subtitle: string;
  image: string;
  tag: string;
  align: OverlayPosition;
};

const usedHomeImages = new Set<string>();

function homeImage(text: string, seed: string, category = '') {
  const image = getImageForText(text, seed, category, undefined, [...usedHomeImages]);
  usedHomeImages.add(image.src);
  return image.src;
}

const homeImages = {
  curbAppeal: homeImage(
    'luxury curb appeal front yard landscaping American home stone entry shrubs',
    'home-curb-appeal',
    'Curb Appeal Landscaping Ideas'
  ),
  walkwayTrend: homeImage(
    'front walkway landscaping pavers border plants path lights American home',
    'home-walkway-trend',
    'Walkway Landscaping Ideas'
  ),
  porchGarden: homeImage(
