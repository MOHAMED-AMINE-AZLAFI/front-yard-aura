    'Front Yard Flower Bed Ideas'
  ),
  galleryBudget: homeImage(
    'affordable front yard landscaping mulch edging porch planters',
    'home-gallery-budget',
    'Front Yard Landscaping On A Budget'
  ),
  gallerySmall: homeImage(
    'small front yard landscaping townhome compact walkway flower beds',
    'home-gallery-small',
    'Small Front Yard Landscaping Ideas'
  ),
  galleryCurb: homeImage(
    'classic American home curb appeal foundation beds shrubs walkway',
    'home-gallery-curb',
    'Curb Appeal Landscaping Ideas'
  ),
  galleryLowMaintenance: homeImage(
    'low maintenance front yard drought tolerant shrubs gravel mulch',
    'home-gallery-low-maintenance',
    'Low Maintenance Front Yard Landscaping'
  ),
  newsletter: photo('photo-1564013799919-ab600027ffc6', 1000, 1500, 84)
