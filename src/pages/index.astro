    'home-transformation-entry',
    'Curb Appeal Landscaping Ideas'
  ),
  transformationWalkway: homeImage(
    'front walkway garden arrival after landscaping border plants pavers',
    'home-transformation-walkway',
    'Walkway Landscaping Ideas'
  ),
  galleryModern: homeImage(
    'modern front yard pavers ornamental grasses clean exterior landscaping',
    'home-gallery-modern',
    'Modern Front Yard Landscaping'
  ),
  galleryRocks: homeImage(
    'front yard rock garden boulders gravel shrubs American home',
