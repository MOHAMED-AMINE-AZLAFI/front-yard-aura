const trendingIdeas: HomeImageCard[] = [
  {
    title: 'Layered Modern Entry',
    label: 'Trending',
    image: homeImages.curbAppeal,
    position: 'bottom',
    copy: 'Clean architecture softened with clipped greens, stone texture, and warm path lighting.'
  },
  {
    title: 'Estate Walkway Borders',
    label: 'Walkways',
    image: homeImages.walkwayTrend,
    position: 'top',
    copy: 'A save-worthy approach with structured planting and calm symmetry.'
  },
  {
    title: 'Soft Porch Garden',
    label: 'Porches',
    image: homeImages.porchGarden,
    position: 'center',
    copy: 'Planters, hedges, and flower color that feel polished without trying too hard.'
  }
];

const ideaSections: HomeIdeaSection[] = [
  {
    title: 'Modern Front Yard Landscaping',
    subtitle: 'Architectural planting, confident negative space, and crisp curb appeal.',
    image: homeImages.modern,
    tag: 'Modern',
    align: 'bottom'
  },
  {
    title: 'Budget Landscaping Ideas',
    subtitle: 'High-impact upgrades using mulch discipline, edging, lighting, and repeatable planting.',
    image: homeImages.budget,
    tag: 'Smart Spend',
    align: 'top'
  },
  {
    title: 'Small Front Yard Ideas',
    subtitle: 'Compact designs with layered depth, entry framing, and no wasted square footage.',
    image: homeImages.small,
    tag: 'Small Yard',
    align: 'center'
  },
  {
    title: 'Flower Bed Inspiration',
    subtitle: 'Editorial flower beds with seasonal rhythm, texture, and curb appeal color.',
    image: homeImages.flowerBeds,
    tag: 'Flowers',
    align: 'bottom'
  },
  {
