---
interface Props {
  id: string;
  label?: string;
  class?: string;
}

const { id, label = 'Advertisement', class: className = '' } = Astro.props;
---

<aside
  id={id}
  class={`my-8 min-h-24 rounded-lg border border-dashed border-aura-sage/40 bg-aura-porcelain/75 p-4 text-center text-xs font-bold uppercase text-aura-ink/45 ${className}`}
  aria-label={label}
  data-ad-slot={id}
  data-adsense-placeholder="true"
>
  {label}
</aside>
