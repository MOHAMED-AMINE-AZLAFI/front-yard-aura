---
import BrandLogo from '@/components/BrandLogo.astro';
import { SITE } from '@/lib/site';

const year = new Date().getFullYear();
---

<footer class="bg-aura-forest text-aura-ivory">
  <div class="container-page grid gap-10 py-14 md:grid-cols-[1fr_auto] md:items-center">
    <div>
      <BrandLogo variant="light" class="h-14 w-auto" />
      <p class="mt-4 max-w-2xl text-sm leading-6 text-aura-ivory/72">{SITE.description}</p>
      <div class="mt-6 flex flex-wrap gap-2">
        {['Luxury Ideas', 'Curb Appeal', 'Garden Design'].map((item) => (
          <span class="rounded-full border border-white/10 bg-white/5 px-3 py-2 text-xs font-bold text-aura-ivory/70">{item}</span>
        ))}
      </div>
    </div>
    <div class="flex flex-wrap gap-4 text-sm font-bold text-aura-ivory/80 md:justify-end">
      <a class="transition hover:text-aura-brass" href="/privacy/">Privacy</a>
      <a class="transition hover:text-aura-brass" href="/contact/">Contact</a>
      <a class="transition hover:text-aura-brass" href={SITE.social.pinterest} rel="me noopener" target="_blank">Pinterest</a>
    </div>
  </div>
  <div class="border-t border-white/10 py-4 text-center text-xs text-aura-ivory/55">
    &copy; {year} {SITE.name}. All rights reserved.
  </div>
</footer>
