---
import BrandLogo from '@/components/BrandLogo.astro';
import { NAV_ITEMS, SITE } from '@/lib/site';
---

<header class="sticky top-0 z-50 border-b border-aura-linen/80 bg-aura-porcelain/92 backdrop-blur-xl">
  <div class="container-page flex min-h-20 items-center justify-between gap-4">
    <a href="/" class="flex shrink-0 items-center" aria-label={`${SITE.name} home`}>
      <BrandLogo variant="main" class="h-10 w-auto sm:h-14" />
    </a>
    <nav class="hidden items-center gap-1 rounded-full border border-aura-linen bg-aura-porcelain/80 p-1 text-sm font-bold text-aura-ink shadow-soft md:flex" aria-label="Primary navigation">
      {NAV_ITEMS.map((item) => (
        <a class="rounded-full px-4 py-2 transition-all duration-300 hover:bg-aura-mist hover:text-aura-pine" href={item.href}>{item.label}</a>
      ))}
    </nav>
    <div class="flex items-center gap-2">
      <a href="/blog/" class="btn-primary hidden lg:inline-flex">Read Ideas</a>
    </div>
  </div>
  <nav class="container-page flex gap-2 overflow-x-auto pb-3 text-xs font-bold text-aura-ink/70 md:hidden" aria-label="Mobile navigation">
    {NAV_ITEMS.map((item) => (
      <a class="shrink-0 rounded-full border border-aura-linen bg-aura-porcelain px-4 py-2 transition" href={item.href}>{item.label}</a>
    ))}
  </nav>
</header>
