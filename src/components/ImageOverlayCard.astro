---
import type { OverlayPosition } from '@/data/images';

interface Props {
  src: string;
  alt: string;
  title: string;
  label?: string;
  description?: string;
  position?: OverlayPosition;
  href?: string;
  loading?: 'eager' | 'lazy';
  class?: string;
}

const {
  src,
  alt,
  title,
  label,
  description,
  position = 'bottom',
  href,
  loading = 'lazy',
  class: className = ''
} = Astro.props;

const align = position === 'top' ? 'items-start' : position === 'center' ? 'items-center' : 'items-end';
const Tag = href ? 'a' : 'article';
---

<Tag href={href} class={`premium-card image-zoom group relative flex aspect-[2/3] overflow-hidden p-5 ${align} ${className}`}>
  <img class="absolute inset-0 h-full w-full object-cover" src={src} alt={alt} width="1000" height="1500" loading={loading} decoding="async" />
  <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(12,33,24,0.16)_0%,rgba(12,33,24,0.42)_45%,rgba(12,33,24,0.88)_100%)]" aria-hidden="true"></div>
  <div class="image-copy-panel relative max-w-md">
    {label && <p class="image-copy-kicker">{label}</p>}
    <h3 class="image-copy-title mt-2">{title}</h3>
    {description && <p class="image-copy-body">{description}</p>}
  </div>
</Tag>
