---
import { CATEGORIES } from '@/data/categories';
import { getImageForText } from '@/data/images';

const usedShowcaseImages = new Set<string>();
const categories = CATEGORIES.map((item, index) => {
  const image = getImageForText(
    [
      item.name,
      item.shortName,
      item.slug,
      item.description,
      item.seoTitle,
      item.seoDescription,
      item.intro,
      item.imageAlt,
      item.accent,
      ...item.cards.flatMap((card) => [card.title, card.description])
    ].join(' '),
    `category-showcase-${item.slug}`,
    item.name,
    1200 + index * 29,
    [...usedShowcaseImages]
  );
  usedShowcaseImages.add(image.src);
  return { ...item, imageMatch: image };
});
---

<section class="bg-aura-ivory py-12 md:py-16">
  <div class="container-page">
    <div class="grid gap-8 md:grid-cols-[0.85fr_1.15fr] md:items-start">
      <div class="md:sticky md:top-28">
        <p class="eyebrow">Explore By Mood</p>
        <h2 class="mt-3 font-serif text-4xl font-bold leading-tight text-aura-pine md:text-5xl">
          Premium categories with magazine-style scanning.
        </h2>
        <p class="mt-4 text-sm leading-7 text-aura-ink/85">
          Built for future SEO clusters while keeping the browsing experience visual, calm, and high-trust.
        </p>
      </div>
      <div class="grid gap-4 sm:grid-cols-2">
        {categories.map((item, index) => (
          <a class={`premium-card group overflow-hidden p-5 ${index % 2 === 1 ? 'sm:mt-10' : ''}`} href={`/ideas/${item.slug}/`}>
            <div class="image-zoom aspect-[4/3]">
              <img
                class="h-full w-full object-cover"
                src={item.imageMatch.src}
                alt={item.imageMatch.alt}
                width="1000"
                height="750"
                loading="lazy"
                decoding="async"
              />
            </div>
            <div class="pt-5">
              <p class="text-xs font-bold uppercase text-aura-clay">0{index + 1}</p>
              <h3 class="mt-2 font-serif text-3xl font-semibold leading-tight text-aura-pine">{item.name}</h3>
              <p class="mt-3 text-sm leading-6 text-aura-ink/85">{item.description}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>
