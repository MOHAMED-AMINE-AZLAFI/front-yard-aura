---
interface Props {
  author?: string;
}

const { author = 'Front Yard Aura Editorial' } = Astro.props;
---

<aside class="premium-card my-10 p-6">
  <p class="eyebrow">Written By</p>
  <div class="mt-4 flex gap-4">
    <img src="/brand/mark.svg" alt="Front Yard Aura editorial mark" class="h-14 w-14 rounded-full" width="96" height="96" loading="lazy" />
    <div>
      <h2 class="font-serif text-2xl font-semibold text-aura-pine">{author}</h2>
      <p class="mt-2 text-sm leading-6 text-aura-ink/85">
        Editorial guidance for premium front yard landscaping ideas, curb appeal, planting design, and Pinterest-ready exterior inspiration.
      </p>
    </div>
  </div>
</aside>
