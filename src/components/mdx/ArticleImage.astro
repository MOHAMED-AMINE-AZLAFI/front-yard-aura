---
import PinterestSave from '@/components/PinterestSave.astro';
import { getImageForArticleSection } from '@/data/images';

interface Props {
  src: string;
  alt: string;
  caption?: string;
  overlay?: string;
  context?: string;
  category?: string;
  title?: string;
  slug?: string;
  heading?: string;
  previousParagraph?: string;
  nextParagraph?: string;
  position?: 'top' | 'center' | 'bottom';
}

const {
  src,
  alt,
  caption,
  overlay,
  context,
  category,
  title,
  slug,
  heading,
  previousParagraph,
  nextParagraph,
  position = 'bottom'
} = Astro.props;
const imageSeed = [context, src, alt, caption, overlay, position].filter(Boolean).join('|');
const imageMatch = getImageForArticleSection({
  title: title ?? context,
  category,
  slug,
  heading: heading ?? context,
  previousParagraph: previousParagraph ?? context,
  nextParagraph,
  alt,
  caption,
  overlay,
  seed: imageSeed
});
const imageSrc = imageMatch.src;
const imageAlt = alt || imageMatch.alt;
const align = position === 'top' ? 'items-start' : position === 'center' ? 'items-center' : 'items-end';
---

<figure class="not-prose my-10">
  <div class={`image-zoom relative flex aspect-[2/3] overflow-hidden rounded-[1.25rem] shadow-premium ${align}`}>
    <img class="absolute inset-0 h-full w-full object-cover" src={imageSrc} alt={imageAlt} width="1000" height="1500" loading="lazy" decoding="async" />
    {overlay && <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(12,33,24,0.16)_0%,rgba(12,33,24,0.40)_44%,rgba(12,33,24,0.88)_100%)]" aria-hidden="true"></div>}
    <div class="absolute right-4 top-4 z-10 opacity-95 transition hover:opacity-100">
      <PinterestSave media={imageSrc} description={overlay ?? imageAlt} class="px-3 py-2 text-xs" />
    </div>
    {overlay && (
      <div class="image-copy-panel relative m-5 max-w-lg">
        <p class="image-copy-title">{overlay}</p>
      </div>
    )}
  </div>
  {caption && <figcaption class="mt-3 text-center text-sm text-aura-ink/60">{caption}</figcaption>}
</figure>
