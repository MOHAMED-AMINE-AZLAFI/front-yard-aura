---
interface Props {
  href: string;
  title: string;
  description?: string;
  label?: string;
}

const { href, title, description, label = 'Related Guide' } = Astro.props;
---

<aside class="not-prose my-8">
  <a class="premium-card block p-6" href={href}>
    <p class="eyebrow">{label}</p>
    <h3 class="mt-3 font-serif text-3xl font-semibold leading-tight text-aura-pine">{title}</h3>
    {description && <p class="mt-3 text-sm leading-6 text-aura-ink/85">{description}</p>}
  </a>
</aside>
